{
  "name": "ets2-freight-system",
  "version": "1.1.0",
  "private": true,
  "description": "Sistema completo de fretes ETS2 com backend, Electron e painel admin.",
  "workspaces": [
    "backend",
    "client"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "start": "npm --workspace backend start",
    "dev:backend": "npm --workspace backend run dev",
    "dev:client": "npm --workspace client start",
    "build:client": "npm --workspace client run build",
    "seed:admin": "npm --workspace backend run seed:admin"
  }
}

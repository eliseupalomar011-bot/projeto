{
  "name": "@ets2-freight/client",
  "version": "1.1.0",
  "description": "Tablet de bordo profissional para Euro Truck Simulator 2",
  "author": "Eliseu Palomar Logistics",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-store": "^8.2.0",
    "socket.io-client": "^4.8.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ets2freight.client",
    "productName": "ETS2 Freight Pro Tablet",
    "copyright": "Copyright © 2026 Eliseu Palomar Logistics",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "publisherName": "Eliseu Palomar"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ETS2 Freight Tablet",
      "artifactName": "ETS2_Freight_Setup_${version}.${ext}"
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  }
}
